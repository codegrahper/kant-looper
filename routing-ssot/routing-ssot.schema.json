{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kant-looper.local/schemas/routing-ssot.schema.json",
  "title": "Kant Looper Routing SSOT",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document",
    "governance",
    "agent_bindings",
    "providers",
    "models",
    "task_tiers",
    "routes",
    "selection_policy",
    "review_policy",
    "execution_policy",
    "evaluation_policy",
    "update_policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "effective_date",
        "last_verified_at",
        "owner",
        "approval_required",
        "source_of_truth",
        "generated_docs"
      ],
      "properties": {
        "id": {
          "const": "kant-looper-routing-ssot"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "draft",
            "active",
            "superseded",
            "retired"
          ]
        },
        "effective_date": {
          "type": "string",
          "format": "date"
        },
        "last_verified_at": {
          "type": "string",
          "format": "date"
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "approval_required": {
          "const": true
        },
        "source_of_truth": {
          "const": true
        },
        "generated_docs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "governance": {
      "type": "object"
    },
    "agent_bindings": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "display_name"
        ],
        "properties": {
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "allowed_model_patterns": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "denied_model_patterns": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "providers": {
      "type": "object",
      "minProperties": 2,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "display_name",
          "official_sources"
        ],
        "properties": {
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "official_sources": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      }
    },
    "models": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider",
          "model_id",
          "agent_tool",
          "status",
          "tier",
          "capabilities",
          "context_tokens",
          "recommended_tiers",
          "verified_at",
          "sources"
        ],
        "properties": {
          "provider": {
            "type": "string"
          },
          "model_id": {
            "type": "string",
            "minLength": 1
          },
          "agent_tool": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "stable",
              "preview",
              "proposed",
              "legacy",
              "deprecated",
              "disabled"
            ]
          },
          "tier": {
            "enum": [
              "economy",
              "standard",
              "premium",
              "specialized"
            ]
          },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "context_tokens": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "recommended_tiers": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": [
                "T0",
                "T1",
                "T2",
                "T3",
                "T4"
              ]
            }
          },
          "verified_at": {
            "type": "string",
            "format": "date"
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      }
    },
    "task_tiers": {
      "type": "object",
      "required": [
        "T0",
        "T1",
        "T2",
        "T3",
        "T4"
      ],
      "additionalProperties": {
        "type": "object"
      }
    },
    "routes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "eligible_tiers",
          "required_capabilities",
          "primary",
          "fallbacks",
          "max_attempts_per_model"
        ],
        "properties": {
          "eligible_tiers": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": [
                "T0",
                "T1",
                "T2",
                "T3",
                "T4"
              ]
            }
          },
          "required_capabilities": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "primary": {
            "type": "string",
            "pattern": "^(codex|opencode|grok|agy|claude)\\|[^|]+/[^|]+$"
          },
          "fallbacks": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^(codex|opencode|grok|agy|claude)\\|[^|]+/[^|]+$"
            }
          },
          "harness": {
            "type": "string"
          },
          "status": {
            "enum": [
              "active",
              "proposed",
              "retired"
            ]
          },
          "max_attempts_per_model": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          }
        }
      }
    },
    "selection_policy": {
      "type": "object"
    },
    "review_policy": {
      "type": "object"
    },
    "execution_policy": {
      "type": "object"
    },
    "no_progress_policy": {
      "type": "object"
    },
    "evaluation_policy": {
      "type": "object"
    },
    "update_policy": {
      "type": "object"
    }
  }
}
